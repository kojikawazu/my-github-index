---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 sm:py-10">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    <p class="mt-2 text-sm text-slate-600 sm:text-base">{subtitle}</p>
  </div>
</header>
