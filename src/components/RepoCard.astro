---
import type { DisplayRepo } from "../lib/github";

interface Props {
  repo: DisplayRepo;
}

const { repo } = Astro.props;
---

<article class="group h-full rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:border-slate-300 hover:shadow-md">
  <h2 class="text-lg font-semibold text-slate-900">
    <a
      href={repo.url}
      target="_blank"
      rel="noopener noreferrer"
      class="after:absolute after:inset-0 hover:text-blue-700"
    >
      <span class="relative">{repo.name}</span>
    </a>
  </h2>
  {repo.description && (
    <p class="mt-2 line-clamp-3 text-sm text-slate-600">{repo.description}</p>
  )}
</article>
